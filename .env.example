# === Required ===
LITELLM_MASTER_KEY=sk-change-me-to-a-real-key

# === Ollama (self-hosted) ===
# Use 127.0.0.1 with network_mode: host (iptables disabled)
OLLAMA_API_BASE=http://127.0.0.1:11434
# Use host.docker.internal with bridge network (iptables enabled)
# OLLAMA_API_BASE=http://host.docker.internal:11434

# === Cloud providers (optional) ===
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# AZURE_API_KEY=
# AZURE_API_BASE=
# AZURE_API_VERSION=

# === Debug ===
# LITELLM_LOG=DEBUG
